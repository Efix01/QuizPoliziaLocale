rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // 🛠️ FUNZIONI HELPER
    // =========================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'efix01@gmail.com';
    }

    function isValidPercentage(value) {
      return value is number && value >= 0 && value <= 100;
    }

    function isNonNegativeInt(value) {
      return value is int && value >= 0;
    }

    // =========================================================
    // REGOLA GLOBALE: Deny all default
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================
    // UTENTI: Struttura a sub-collection specializzate
    // =========================================================
    match /users/{userId} {
      
      // Profilo Utente
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId)
                    && request.resource.size < 10240
                    && request.resource.data.keys().hasOnly([
                      'email', 'displayName', 'createdAt', 'lastSeen', 'photoURL', 'uid'
                    ]);

      allow update: if isOwner(userId)
                    && request.resource.size < 10240
                    && request.resource.data.keys().hasOnly([
                      'email', 'displayName', 'createdAt', 'lastSeen', 'photoURL', 'uid'
                    ]);

      allow delete: if isAdmin();

      // Progressi Globali (Main e altri)
      match /progressi/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        
        allow create: if isOwner(userId)
                      && request.resource.size < 20480
                      && request.resource.data.keys().hasOnly([
                        '_schemaVersion', 'quizCompletati', 'risposteCorrette', 
                        'mediaPercentuale', 'streak', 'livello', 'xp', 
                        'capitoliLetti', 'domandeSalvate', 'perCategoria', 'ultimoAccesso', 'lastUpdated'
                      ])
                      && isNonNegativeInt(request.resource.data.quizCompletati)
                      && isValidPercentage(request.resource.data.mediaPercentuale)
                      && isNonNegativeInt(request.resource.data.streak)
                      && isNonNegativeInt(request.resource.data.xp);

        allow update: if isOwner(userId)
                      && request.resource.size < 20480
                      && request.resource.data.keys().hasOnly([
                        '_schemaVersion', 'quizCompletati', 'risposteCorrette', 
                        'mediaPercentuale', 'streak', 'livello', 'xp', 
                        'capitoliLetti', 'domandeSalvate', 'perCategoria', 'ultimoAccesso', 'lastUpdated'
                      ])
                      && isNonNegativeInt(request.resource.data.quizCompletati)
                      && isValidPercentage(request.resource.data.mediaPercentuale)
                      && isNonNegativeInt(request.resource.data.streak)
                      && isNonNegativeInt(request.resource.data.xp)
                      // ANTI-CHEAT XP: Non puoi saltare più di 5000 XP in un singolo blocco di salvataggio
                      && (request.resource.data.xp - resource.data.xp) <= 5000;
                      
        allow delete: if isAdmin();
      }

      // Dati SRS
      match /srsData/{domandaId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId)
                     && request.resource.size < 5120
                     && request.resource.data.keys().hasAll(['domandaId', 'nextReview', 'interval'])
                     && isNonNegativeInt(request.resource.data.interval)
                     && request.resource.data.domandaId == domandaId;
      }

      // Log Errori
      match /errori/{domandaId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId)
                     && request.resource.size < 5120
                     && request.resource.data.keys().hasAll(['domandaId', 'count', 'lastError'])
                     && isNonNegativeInt(request.resource.data.count)
                     && request.resource.data.domandaId == domandaId;
      }
      
      // Legacy path (per migrazione)
      match /pl_progress/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
        allow delete: if isAdmin();
      }
    }

    // =========================================================
    // DATI PUBBLICI
    // =========================================================
    match /domande_core/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /regioni/{regioneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /comuni/{comuneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Inbox per l'importazione e l'aggiornamento dei quiz
    match /bozze_aggiornamenti/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
